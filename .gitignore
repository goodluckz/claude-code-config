# Claude Code Configuration .gitignore
# Ignore generated, cached, and session-specific files

# Session and Conversation Data
/projects/
/history.jsonl
/shell-snapshots/
/session-env/
/sessions/

# Task and Plan Tracking (session-specific)
/todos/
/plans/
/tasks/

# Debug and Diagnostic Logs
/debug/
/file-history/

# Plugin Downloads and Caches
/plugins/cache/
/plugins/marketplaces/
/plugins/blocklist.json

# Analytics and Usage Data
/stats-cache.json
/statsig/
/telemetry/

# Cache and Temporary Data
/cache/
/downloads/
/paste-cache/
/backups/

# IDE and Runtime State
/ide/

# MCP Configuration and Cache
/mcp.json
/mcp-needs-auth-cache.json

# Local Settings (not shared)
/settings.local.json

# Credentials and Secrets
/.credentials.json

# System Files
.DS_Store
*.swp
*.swo
*~
.vscode/
.idea/

# Keep these files - they contain valuable configuration
!/.gitignore
!/settings.json
!/plugins/known_marketplaces.json
!/plugins/installed_plugins.json
!/skills/
!/CLAUDE.md
